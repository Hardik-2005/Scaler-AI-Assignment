# Duplicate this file as `.env.docker` and fill in your keys. This file WILL NOT be checked in to source control.

# ========================
# DATABASE
# ========================
# Matches docker-compose variables for MySQL container
DATABASE_URL=mysql://flipkart_user:flipkart_password@mysql:3306/flipkart_clone

# ========================
# BACKEND (Express)
# ========================
PORT=5000
# Keep blank for actual secrets - DO NOT COMMIT THE ACTUAL CLERK KEYS
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
EMAIL_USER=YOUR_EMAIL_FOR_NODEMAILER
EMAIL_PASS=YOUR_EMAIL_APP_PASSWORD

# ========================
# FRONTEND (Next.js)
# ========================
NEXT_PUBLIC_API_URL=http://localhost:5000
# Clerk Public Key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
